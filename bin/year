#!/usr/bin/env python

import datetime as dt


def main():
    today = dt.date.today()
    month, day = today.month, today.day
    if (month, day) < (2, 2) or (month, day) >= (12, 21):
        return "✨❄️"  # W2
    if (month, day) < (3, 21):
        return "❄️🌱"  # F1
    if (month, day) < (5, 1):
        return "🌱🌸"  # F2
    if (month, day) < (6, 21):
        return "🌸☀️"  # S1
    if (month, day) < (8, 1):
        return "☀️🌾"  # S2
    if (month, day) < (9, 21):
        return "🌾🍁"  # H1
    if (month, day) < (11, 11):
        return "🍁🕯️"  # H2
    if (month, day) < (12, 21):
        return "🕯️✨"  # W1
    return


print(main())
