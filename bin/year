#!/usr/bin/env python

import datetime as dt


def main():
    today = dt.date.today()
    month, day = today.month, today.day
    if (month, day) < (2, 2) or (month, day) >= (12, 21):
        return "✨❄️"
    if (month, day) < (3, 21):
        return "❄️🌱"
    if (month, day) < (5, 1):
        return "🌱🌸"
    if (month, day) < (6, 21):
        return "🌸☀️"
    if (month, day) < (8, 2):
        return "☀️🌾"
    if (month, day) < (9, 21):
        return "🌾🍁"
    if (month, day) < (11, 1):
        return "🍁🕯️"
    if (month, day) < (12, 21):
        return "🕯️✨"
    return


print(main())
